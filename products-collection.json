    {
      "name": "Sayfalanmış Ürün Listesi",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Durum Kodu Kontrolü (Zorunlu)",
              "pm.test(\"Status code is 200\", () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// 2. Yanıt Süresi Kontrolü (Zorunlu)",
              "pm.test(\"Response time is less than 2000ms\", () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000); ",
              "});",
              "",
              "// 3. İçerik ve Alan Kontrolü (Zorunlu)",
              "pm.test(\"Response contains products, total, skip, and limit\", () => {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.all.keys('products', 'total', 'skip', 'limit'); ",
              "});",
              "",
              "// 4. JSON Schema Validation (Ödevde Bu Endpoint İçin Zorunlu)",
              "const schema = {",
              "    type: \"object\",",
              "    required: [\"products\", \"total\", \"skip\", \"limit\"],",
              "    properties: {",
              "        products: {",
              "            type: \"array\",",
              "            items: {",
              "                type: \"object\",",
              "                required: [\"id\", \"title\", \"price\", \"category\", \"thumbnail\"]",
              "            }",
              "        },",
              "        total: { type: \"number\" },",
              "        skip: { type: \"number\" },",
              "        limit: { type: \"number\" }",
              "    }",
              "};",
              "",
              "pm.test(\"JSON Schema is valid\", () => {",
              "    pm.response.to.have.jsonSchema(schema); ",
              "});",
              "",
              "// 5. Ek Assertion (Bonus Puan İçin)",
              "pm.test(\"Products list is an array and has correct length\", () => {",
              "    const data = pm.response.json();",
              "    pm.expect(data.products).to.be.an(\"array\"); ",
              "    pm.expect(data.products.length).to.eql(5); // limit=5 olduğu için ",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
