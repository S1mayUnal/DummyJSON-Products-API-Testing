    {
      "name": "Giriş → accessToken al",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();\r",
              "\r",
              "// Başarılı bir yanıt geldiyse ve accessToken varsa kaydet\r",
              "pm.test(\"Giriş başarılı ve token alındı\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    pm.expect(res).to.have.property('accessToken');\r",
              "    \r",
              "    // Değişkeni çevreye kaydet\r",
              "    pm.environment.set(\"authToken\", res.accessToken);\r",
              "});\r",
              "// 1. Status Code Kontrolü\r",
              "pm.test(\"Status code is 200\", function () { \r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Response Time Kontrolü \r",
              "pm.test(\"Response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// 3. Body ve İçerik Kontrolü \r",
              "pm.test(\"Content-Type is application/json\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// Ek kontrol: Token gerçekten set edildi mi?\r",
              "console.log(\"Kaydedilen Token: \" + pm.environment.get(\"authToken\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
