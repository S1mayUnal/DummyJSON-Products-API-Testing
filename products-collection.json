              "});",
              "",
              "// 2. Response Time Kontrolü ",
              "pm.test(\"Response time is less than 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// 3. Body ve İçerik Kontrolü ",
              "pm.test(\"Content-Type is application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Rastgele marka ve fiyat üretme scripti\r",
              "const brands = [\"Apple\", \"Samsung\", \"Sony\", \"LG\", \"Huawei\", \"Xiaomi\", \"Oppo\"];\r",
              "const randomBrand = brands;\r",
              "const randomPrice = Math.floor(Math.random() * 5000) + 100; \r",
              "\r",
              "// Üretilen değerleri çevre değişkenlerine (environment) kaydet \r",
              "pm.environment.set(\"randomBrand\", randomBrand);\r",
              "pm.environment.set(\"randomPrice\", randomPrice);\r",
              "\r",
              "// Console üzerinden kontrol etmek için (Opsiyonel)\r",
              "console.log(\"Üretilen Marka: \" + randomBrand);\r",
              "console.log(\"Üretilen Fiyat: \" + randomPrice);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"title\": \"Yeni Nesil Akıllı Telefon\",\n    \"description\": \"Otomatik test ile oluşturulmuştur.\",\n    \"price\": {{randomPrice}},\n    \"brand\": \"{{randomBrand}}\",\n    \"category\": \"smartphones\"\n}\n",
          "options": {
            "raw": {
              "language": "json"
